---
import { url } from "../utils/url-utils";
---

<footer class="site-footer">
  <div class="footer-line">
    © 2026 Ytx. 保留所有权利。 RSS · 站点地图
  </div>
  <div class="footer-powered">
    Powered by Ytx & apple & Gemini。
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    padding: 24px 0 16px;
    background: var(--footer-bg, var(--bg-base));
    border-top: 1px solid var(--border-subtle);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer-line {
    font-family: var(--font-text);
    font-size: 12px;
    color: var(--text-tertiary);
    margin: 0;
    opacity: 0.7;
  }

  .footer-powered {
    margin-top: 4px;
    font-family: var(--font-text);
    font-size: 12px;
    color: var(--text-tertiary);
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .site-footer {
      padding: 14px 0 10px 0;
    }
    .footer-line,
    .footer-powered {
      font-size: 11px;
    }
  }
</style>
