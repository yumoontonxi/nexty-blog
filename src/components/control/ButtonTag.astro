---
interface Props {
	size?: string;
	dot?: boolean;
	href?: string;
	label?: string;
}
const { href, label }: Props = Astro.props;
---
<a href={href} aria-label={label} class="sidebar-tag">
    <slot></slot>
</a>

<style>
    .sidebar-tag {
        font-family: var(--font-sans);
        font-size: 0.875rem;
        color: var(--text-secondary);
        text-decoration: none;
        transition: color var(--transition-duration) var(--transition-ease);
        background: none;
        padding: 0;
    }

    .sidebar-tag:hover {
        color: var(--text-primary);
    }
</style>
