---
import { Icon } from "astro-icon/components";
---

<div class="back-to-top-wrapper hidden lg:block">
    <div id="back-to-top-btn" class="back-to-top-btn hide" onclick="backToTop()">
        <button aria-label="Back to Top" class="glass-control flex h-14 w-14 items-center justify-center">
            <Icon name="material-symbols:keyboard-arrow-up-rounded" class="text-[1.75rem] text-white/45 transition-colors"></Icon>
        </button>
    </div>
</div>

<style>
    .back-to-top-wrapper {
        width: 3.5rem;
        height: 3.5rem;
        position: absolute;
        right: 0;
        top: 0;
        pointer-events: none;
    }

    .back-to-top-btn {
        position: fixed;
        bottom: 10rem;
        border: none;
        cursor: pointer;
        opacity: 1;
        transform: translateX(5rem);
        pointer-events: auto;
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .back-to-top-btn.hide {
        transform: translateX(5rem);
        opacity: 0;
        pointer-events: none;
    }

    .back-to-top-btn:hover :global(svg) {
        color: rgba(165, 243, 252, 0.9);
    }
</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}
</script>
