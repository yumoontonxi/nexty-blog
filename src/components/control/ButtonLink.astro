---
interface Props {
	badge?: string;
	url?: string;
	label?: string;
}
const { badge, url, label } = Astro.props;
---
<a href={url} aria-label={label} class="category-row">
    <span class="category-name"><slot></slot></span>
    {badge !== undefined && badge !== null && badge !== '' && (
        <span class="category-count">{badge}</span>
    )}
</a>

<style>
    .category-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 36px;
        text-decoration: none;
        background: none;
    }

    .category-name {
        font-family: var(--font-text);
        font-size: 14px;
        color: var(--text-secondary);
        transition: color var(--duration-fast) ease;
    }

    .category-row:hover .category-name {
        color: var(--text-primary);
    }

    .category-count {
        font-family: var(--font-text);
        font-size: 14px;
        color: var(--text-tertiary);
        text-align: right;
    }
</style>
