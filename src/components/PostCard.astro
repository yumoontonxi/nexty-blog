---
import path from "node:path";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import type { PostSource } from "../utils/posts-merge";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { getDir } from "../utils/url-utils";
import ImageWrapper from "./misc/ImageWrapper.astro";

interface Props {
	class?: string;
	source: PostSource;
	entryId?: string;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string | null;
	image: string;
	description: string;
	draft: boolean;
	style: string;
}
const {
	source,
	entryId,
	title,
	url,
	published,
	category,
	image,
} = Astro.props;

const hasCover = image !== undefined && image !== null && image !== "";
const categoryLabel = (category || i18n(I18nKey.uncategorized)).toUpperCase();
const dateLabel = formatDateToYYYYMMDD(published);
const imageBasePath =
	source === "local" && entryId
		? path.join("content/posts/", getDir(entryId))
		: undefined;
---
<article class="post-row">
    <a
        href={url}
        class="post-row-link"
        aria-label={title}
        data-no-swup={source === "notion" || undefined}
    >
        <div class="post-row-main">
            <div class:list={["post-thumb-wrap", { "post-thumb-placeholder": !hasCover }]}>
                {hasCover && source === "notion" && (
                    <img
                        src={image}
                        alt={title}
                        class="post-thumb post-thumb-img"
                        loading="lazy"
                        decoding="async"
                    />
                )}
                {hasCover && source === "local" && (
                    <ImageWrapper
                        src={image}
                        basePath={imageBasePath}
                        alt=""
                        class="post-thumb"
                    />
                )}
            </div>
            <div class="post-row-text">
                <span class="post-category">{categoryLabel}</span>
                <span class="post-sep">·</span>
                <span class="post-title">{title}</span>
            </div>
        </div>
        <time class="post-date" datetime={published.toISOString()}>
            {dateLabel}
        </time>
    </a>
</article>

<style>
    .post-row {
        border-bottom: 1px solid var(--border-subtle);
    }

    .post-row-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 80px;
        padding: 16px 0;
        text-decoration: none;
        transition: background var(--duration-fast) ease;
    }

    .post-row-link:hover {
        background: var(--row-hover-bg);
    }

    .post-row-main {
        display: flex;
        min-width: 0;
        flex: 1;
        align-items: center;
    }

    .post-thumb-wrap {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        margin-right: 20px;
        overflow: hidden;
        border-radius: 8px;
        background: var(--bg-secondary);
    }

    .post-thumb-placeholder {
        background: var(--bg-tertiary);
    }

    .post-thumb :global(> div) {
        width: 80px !important;
        height: 80px !important;
    }

    .post-thumb :global(> div.absolute) {
        display: none;
    }

    .post-thumb :global(img) {
        width: 80px !important;
        height: 80px !important;
        object-fit: cover;
        border-radius: 8px;
        transition: transform 0.4s var(--ease);
    }

    .post-thumb-img {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
        transition: transform 0.4s var(--ease);
    }

    .post-row-link:hover .post-thumb :global(img),
    .post-row-link:hover .post-thumb-img {
        transform: scale(1.02);
    }

    .post-row-text {
        min-width: 0;
        flex: 1;
    }

    .post-category {
        font-family: var(--font-text);
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 0.08em;
        color: var(--text-tertiary);
        text-transform: uppercase;
    }

    .post-sep {
        margin: 0 0.35em;
        color: var(--text-tertiary);
        font-size: 11px;
    }

    .post-title {
        font-family: var(--font-text);
        font-size: 15px;
        font-weight: 400;
        color: var(--text-primary);
        transition: color var(--duration-fast) ease;
    }

    .post-row-link:hover .post-title {
        color: var(--accent-warm);
    }

    .post-date {
        flex-shrink: 0;
        margin-left: 16px;
        font-family: var(--font-text);
        font-size: 12px;
        color: var(--text-tertiary);
        white-space: nowrap;
    }

    @media (max-width: 767px) {
        .post-thumb-wrap {
            width: 56px;
            height: 56px;
            margin-right: 16px;
        }

        .post-thumb :global(> div) {
            width: 56px !important;
            height: 56px !important;
        }

        .post-thumb :global(img),
        .post-thumb-img {
            width: 56px !important;
            height: 56px !important;
        }

        .post-row-text {
            white-space: normal;
        }

        .post-title {
            display: inline;
        }
    }
</style>
