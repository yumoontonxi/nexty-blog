/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large: 0
  --content-delay: 150ms

define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: #f5f5f7 #f5f5f7
  --page-bg: #000000 #000000
  --card-bg: #2c2c2e #2c2c2e

  --btn-content: #888888 #888888

  --btn-regular-bg: #2c2c2e #2c2c2e
  --btn-regular-bg-hover: #3a3a3c #3a3a3c
  --btn-regular-bg-active: #48484a #48484a

  --btn-plain-bg-hover: #2c2c2e #2c2c2e
  --btn-plain-bg-active: #3a3a3c #3a3a3c

  --btn-card-bg-hover: #2c2c2e #2c2c2e
  --btn-card-bg-active: #3a3a3c #3a3a3c

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: #e5e5e7

  --title-active: #f5f5f7

  --line-divider: rgba(84, 84, 88, 0.3) rgba(84, 84, 88, 0.3)

  --line-color: #38383a #38383a
  --meta-divider: #636366 #636366

  --inline-code-bg: #2c2c2e
  --inline-code-color: #e5e5e7
  --selection-bg: #3a3a3c #3a3a3c
  --codeblock-selection: #48484a
  --codeblock-bg: #2c2c2e #2c2c2e
  --codeblock-topbar-bg: #1c1c1e #1c1c1e

  --license-block-bg: #2c2c2e

  --link-underline: #444444 #444444
  --link-hover: #0d0d0d #0d0d0d
  --link-active: #111111 #111111

  --float-panel-bg: #1c1c1e #1c1c1e

  --scrollbar-bg-light: rgba(255, 255, 255, 0.2)
  --scrollbar-bg-hover-light: rgba(255, 255, 255, 0.3)
  --scrollbar-bg-active-light: rgba(255, 255, 255, 0.4)

  --scrollbar-bg-dark: rgba(255, 255, 255, 0.2)
  --scrollbar-bg-hover-dark: rgba(255, 255, 255, 0.3)
  --scrollbar-bg-active-dark: rgba(255, 255, 255, 0.4)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: #888888 #888888
  --admonitions-color-note: #888888 #888888
  --admonitions-color-important: #cccccc #cccccc
  --admonitions-color-warning: #888888 #888888
  --admonitions-color-caution: #cccccc #cccccc

  --toc-badge-bg: #0a0a0a
  --toc-btn-hover: #0d0d0d #0d0d0d
  --toc-btn-active: #111111 #111111
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: #ffffff #ffffff
})
