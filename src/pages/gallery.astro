---
import CommentsStub from "@components/CommentsStub.astro";
import FullWidthLayout from "../layouts/FullWidthLayout.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

const galleryItems = [
	{
		title: "晨光",
		date: "2026-01-12",
		image: "https://picsum.photos/800/600?random=11",
		alt: "晨光 — 横构图摄影",
	},
	{
		title: "街角",
		date: "2026-02-03",
		image: "https://picsum.photos/600/900?random=22",
		alt: "街角 — 竖构图摄影",
	},
	{
		title: "静物",
		date: "2026-02-18",
		image: "https://picsum.photos/700/500?random=33",
		alt: "静物 — 女儿画作",
	},
	{
		title: "远山",
		date: "2026-03-05",
		image: "https://picsum.photos/600/800?random=44",
		alt: "远山 — 竖构图风景",
	},
	{
		title: "暮色",
		date: "2026-03-22",
		image: "https://picsum.photos/900/600?random=55",
		alt: "暮色 — 宽幅摄影",
	},
	{
		title: "花影",
		date: "2026-04-08",
		image: "https://picsum.photos/650/950?random=66",
		alt: "花影 — 竖构图画作",
	},
];
---

<FullWidthLayout title={i18n(I18nKey.gallery)} description={i18n(I18nKey.gallery)}>
    <div class="gallery-page flex min-h-[calc(100vh-200px)] flex-1 flex-grow flex-col">
        <header class="mb-10">
            <h1 class="text-2xl font-light tracking-wide text-[var(--text-primary)]">
                {i18n(I18nKey.gallery)}
            </h1>
            <p class="mt-2 text-sm text-[var(--text-tertiary)]">
                画作与摄影 · 瀑布流画廊
            </p>
        </header>

        <div class="gallery-masonry columns-1 gap-6 space-y-6 sm:columns-2 lg:columns-3">
            {galleryItems.map((item) => (
                <article
                    class="gallery-card group relative mb-6 cursor-pointer break-inside-avoid overflow-hidden rounded-xl bg-[var(--bg-secondary)] shadow-sm transition-shadow duration-300 hover:shadow-md"
                    data-src={item.image}
                    data-alt={item.alt}
                    data-title={item.title}
                    data-date={item.date}
                    role="button"
                    tabindex="0"
                    aria-label={`查看 ${item.title}`}
                >
                    <img
                        src={item.image}
                        alt={item.alt}
                        class="block w-full transition-transform duration-500 ease-out group-hover:scale-105"
                        loading="lazy"
                        decoding="async"
                    />
                    <div class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent px-4 pb-4 pt-16 opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100">
                        <h2 class="text-sm font-medium tracking-wide text-white">
                            {item.title}
                        </h2>
                        <time class="mt-1 block text-xs text-white/75" datetime={item.date}>
                            {item.date}
                        </time>
                    </div>
                </article>
            ))}
        </div>

        <CommentsStub />
    </div>

    <dialog
        id="lightbox"
        class="lightbox-dialog m-0 h-full max-h-none w-full max-w-none border-none bg-transparent p-0 backdrop:bg-black/90"
        aria-label="图片灯箱"
    >
        <div class="lightbox-inner relative flex h-full w-full items-center justify-center p-6 sm:p-10">
            <button
                id="lightbox-close"
                type="button"
                class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-xl text-white/90 backdrop-blur-sm transition-colors duration-200 hover:bg-white/20 hover:text-white sm:right-8 sm:top-8"
                aria-label="关闭灯箱"
            >
                ✕
            </button>

            <figure class="flex max-h-full max-w-full flex-col items-center gap-4">
                <img
                    id="lightbox-image"
                    src=""
                    alt=""
                    class="max-h-[82vh] max-w-full rounded-lg object-contain shadow-2xl"
                />
                <figcaption class="text-center">
                    <p id="lightbox-title" class="text-base font-medium tracking-wide text-white"></p>
                    <time id="lightbox-date" class="mt-1 block text-sm text-white/60"></time>
                </figcaption>
            </figure>
        </div>
    </dialog>
</FullWidthLayout>

<style>
    .gallery-masonry {
        column-gap: 1.5rem;
    }

    .lightbox-dialog::backdrop {
        background: rgba(0, 0, 0, 0.9);
    }

    .lightbox-dialog[open] {
        animation: lightbox-fade-in 0.28s ease-out;
    }

    .lightbox-dialog[open] #lightbox-image {
        animation: lightbox-zoom-in 0.38s cubic-bezier(0.22, 1, 0.36, 1);
    }

    @keyframes lightbox-fade-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes lightbox-zoom-in {
        from {
            opacity: 0;
            transform: scale(0.94);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<script is:inline>
    (function () {
        let dialogListenersBound = false;

        function initGalleryLightbox() {
            const dialog = document.getElementById("lightbox");
            const image = document.getElementById("lightbox-image");
            const title = document.getElementById("lightbox-title");
            const date = document.getElementById("lightbox-date");
            const closeBtn = document.getElementById("lightbox-close");
            const masonry = document.querySelector(".gallery-masonry");
            const figure = dialog?.querySelector("figure");

            if (!dialog || !image || !masonry) return;

            function openLightbox(card) {
                const src = card.dataset.src;
                const alt = card.dataset.alt || "";
                const cardTitle = card.dataset.title || "";
                const cardDate = card.dataset.date || "";

                if (!src) return;

                image.src = src;
                image.alt = alt;
                if (title) title.textContent = cardTitle;
                if (date) {
                    date.textContent = cardDate;
                    date.setAttribute("datetime", cardDate);
                }

                if (typeof dialog.showModal === "function") {
                    dialog.showModal();
                }
            }

            function closeLightbox() {
                if (dialog.open) dialog.close();
            }

            masonry.onclick = (e) => {
                const card = e.target.closest(".gallery-card");
                if (card) openLightbox(card);
            };

            masonry.querySelectorAll(".gallery-card").forEach((card) => {
                card.onkeydown = (e) => {
                    if (e.key !== "Enter" && e.key !== " ") return;
                    e.preventDefault();
                    openLightbox(card);
                };
            });

            if (!dialogListenersBound) {
                dialogListenersBound = true;

                closeBtn?.addEventListener("click", closeLightbox);

                dialog.addEventListener("click", (e) => {
                    if (e.target === dialog) closeLightbox();
                });

                const inner = dialog.querySelector(".lightbox-inner");
                inner?.addEventListener("click", (e) => {
                    if (e.target === inner) closeLightbox();
                });

                figure?.addEventListener("click", (e) => e.stopPropagation());

                dialog.addEventListener("close", () => {
                    image.removeAttribute("src");
                    image.alt = "";
                });
            }
        }

        function bootGallery() {
            if (!document.querySelector(".gallery-page")) return;
            initGalleryLightbox();
        }

        bootGallery();
        document.addEventListener("astro:page-load", bootGallery);
    })();
</script>
