---
import path from "node:path";
import CommentsStub from "@components/CommentsStub.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import SingleColumnLayout from "@layouts/SingleColumnLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import { profileConfig, siteConfig } from "../../config";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries
		.filter((entry) => !entry.slug.startsWith("notion"))
		.map((entry) => ({
			params: { slug: entry.slug },
			props: { entry },
		}));
}

const slugParam = Astro.params.slug;
if (slugParam === "notion" || slugParam?.startsWith("notion/")) {
	const rawId = slugParam.replace(/^notion\/?/, "");
	return Astro.redirect(`/notion/${rawId.replace(/-/g, "")}/`);
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { remarkPluginFrontmatter } = await entry.render();

const categoryLabel = (entry.data.category || i18n(I18nKey.uncategorized)).toUpperCase();
const dateLabel = formatDateToYYYYMMDD(entry.data.published);
const readTimeLabel = `${remarkPluginFrontmatter.minutes} ${i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}`;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
};
---
<SingleColumnLayout title={entry.data.title} description={entry.data.description} lang={entry.data.lang}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <article class="article-page onload-animation">
        <header class="article-header">
            <h1 class="article-title" data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title">
                {entry.data.title}
            </h1>
            <p class="article-meta">
                <span>{dateLabel}</span>
                <span class="article-meta-sep">·</span>
                <span>{categoryLabel}</span>
                <span class="article-meta-sep">·</span>
                <span>{readTimeLabel}</span>
            </p>
        </header>

        {entry.data.image && (
            <ImageWrapper
                id="post-cover"
                src={entry.data.image}
                basePath={path.join("content/posts/", getDir(entry.id))}
                class="article-cover onload-animation"
            />
        )}

        <Markdown class="article-content markdown-content onload-animation">
            <Content />
        </Markdown>

        {licenseConfig.enable && (
            <License
                title={entry.data.title}
                slug={entry.slug}
                pubDate={entry.data.published}
                class="article-license onload-animation"
            />
        )}
    </article>

    <nav class="article-nav onload-animation" aria-label="Post navigation">
        <a
            href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
            class:list={["article-nav-link article-nav-link--prev", { "is-disabled": !entry.data.nextSlug }]}
        >
            {entry.data.nextSlug && (
                <>
                    <Icon name="material-symbols:chevron-left-rounded" class="article-nav-icon" />
                    <span class="article-nav-label">{entry.data.nextTitle}</span>
                </>
            )}
        </a>
        <a
            href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
            class:list={["article-nav-link article-nav-link--next", { "is-disabled": !entry.data.prevSlug }]}
        >
            {entry.data.prevSlug && (
                <>
                    <span class="article-nav-label">{entry.data.prevTitle}</span>
                    <Icon name="material-symbols:chevron-right-rounded" class="article-nav-icon" />
                </>
            )}
        </a>
    </nav>

    <CommentsStub />
</SingleColumnLayout>

<style>
    .article-page {
        max-width: var(--article-max-width);
        margin: 0 auto;
        padding: 3rem 0 2rem;
        background: var(--bg-primary);
    }

    .article-meta {
        font-family: var(--font-text);
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin: 16px 0 2.5rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.35rem;
    }

    .article-meta-sep {
        color: var(--text-tertiary);
    }

    .article-title {
        font-family: var(--font-display);
        font-size: var(--font-size-title);
        font-weight: 300;
        letter-spacing: 0.02em;
        color: var(--text-primary);
        line-height: 1.25;
        margin: 0;
    }

    .article-cover {
        margin-bottom: 2.5rem;
        border-radius: 12px !important;
        overflow: hidden;
    }

    .article-cover :global(img) {
        width: 100%;
        border-radius: 12px;
    }

    .article-content {
        margin-bottom: 2rem;
    }

    .article-license :global(> div) {
        border-radius: 0 !important;
        border-left: 2px solid var(--accent-warm);
        background: var(--blockquote-bg) !important;
        color: var(--text-secondary);
    }

    .article-nav {
        max-width: var(--article-max-width);
        margin: 0 auto 3rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    @media (min-width: 768px) {
        .article-nav {
            flex-direction: row;
        }
    }

    .article-nav-link {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-subtle);
        text-decoration: none;
        color: var(--text-secondary);
        transition: background var(--duration) var(--ease),
            color var(--duration-fast) ease;
        min-height: 3.5rem;
        overflow: hidden;
    }

    .article-nav-link:hover:not(.is-disabled) {
        background: var(--bg-tertiary);
        color: var(--text-primary);
    }

    .article-nav-link--next {
        justify-content: flex-end;
        text-align: right;
    }

    .article-nav-link.is-disabled {
        pointer-events: none;
        opacity: 0;
        visibility: hidden;
    }

    .article-nav-icon {
        flex-shrink: 0;
        font-size: 1.5rem;
        color: var(--text-primary);
    }

    .article-nav-label {
        font-family: var(--font-text);
        font-size: 0.875rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>
